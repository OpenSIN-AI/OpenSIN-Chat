+          activeIdx={activeThreadIdx}
+          isActive={activeThreadIdx === 0}
+          workspace={workspace}
+          thread={{ slug: null, name: "default" }}
+          hasNext={threads.length > 0 || showVirtualThread}
+        />
+      )}
       {threads.map((thread, i) => (
         <ThreadItem
           key={thread.slug}
-          idx={i + 1}
