+          isActive={activeThreadIdx === i + (defaultThreadHasChats ? 1 : 0)}
           workspace={workspace}
           onRemove={removeThread}
           thread={thread}
-          hasNext={i !== threads.length - 1 || isVirtualThread}
+          hasNext={i !== threads.length - 1 || showVirtualThread}
         />
       ))}
-      {isVirtualThread && (
+      {showVirtualThread && (
         <ThreadItem
           idx={activeThreadIdx}
           activeIdx={activeThreadIdx}
