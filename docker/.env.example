# PGVECTOR_CONNECTION_STRING="postgresql://dbuser:dbuserpass@localhost:5432/yourdb"
# PGVECTOR_TABLE_NAME="opensin_vectors" # optional, but can be defined

# Enable all below if you are using vector database: Chroma.
