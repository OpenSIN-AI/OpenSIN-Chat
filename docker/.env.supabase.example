# Supabase Self-Hosted — Environment Variables
# Copy this file to docker/.env.supabase and fill in the secrets before running:
#   docker compose -f docker/docker-compose.supabase.yml --env-file docker/.env.supabase up -d
#
# Generate secrets:
#   JWT_SECRET      : openssl rand -base64 32
#   ANON_KEY        : use https://supabase.com/docs/guides/self-hosting#api-keys
#                     or: node -e "require('jsonwebtoken').sign({role:'anon'},process.env.JWT_SECRET,{expiresIn:'10y'},(_,t)=>console.log(t))"
#   SERVICE_ROLE_KEY: same as above but with role:'service_role'

###########################################
# PostgreSQL
###########################################
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

###########################################
# JWT
###########################################
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

###########################################
# Supabase API Keys
# These are JWTs signed with JWT_SECRET.
# Generate them at: https://supabase.com/docs/guides/self-hosting#api-keys
###########################################
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlhdCI6MTYxMzUzMTk4NSwiZXhwIjoxOTI5MTA3OTg1fQ.ReNhHIoqGjNMjL9gFNJECvmYYi1SB2K2U7KYDEJ1EFY
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjEzNTMxOTg1LCJleHAiOjE5MjkxMDc5ODV9.th84OKK0Iz9IeFerZ-_QnP72x5V_9yyS_-_oc7g7kLo

###########################################
# Kong API Gateway ports
###########################################
KONG_HTTP_PORT=8000

###########################################
# pg-meta port
###########################################
META_PORT=5433
