{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "./endpoints/**/*",
    "./models/**/*",
    "./utils/**/*",
    "./middleware/**/*",
    "./jobs/**/*",
    "./config/**/*",
    "./swagger/**/*",
    "./index.js",
    "./app.js",
    "./prisma.config.ts"
  ],
  "exclude": ["node_modules", "storage", "dist", "__tests__", "__mocks__"],
  "ts-node": {
    "transpileOnly": true
  }
}
