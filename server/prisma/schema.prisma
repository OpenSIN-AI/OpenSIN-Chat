generator client {
  provider = "prisma-client-js"
}

// SQLite is the active datasource for OpenSIN-Chat (matches
// `server/prisma/migrations/migration_lock.toml` and the runtime
// `server/storage/opensin.db`). The PostgreSQL block is preserved
// upstream-style for optional future migration.
// In Prisma 7 the connection URL lives in prisma.config.ts (or the
// PrismaClient constructor adapter), not in the schema datasource block.
datasource db {
  provider = "sqlite"
}

model api_keys {
  id            Int      @id @default(autoincrement())
  name          String?
  secret        String?  @unique
  createdBy     Int?
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @default(now())
  createdByUser users?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
}

model workspace_documents {
  id                   Int                   @id @default(autoincrement())
  docId                String                @unique
  filename             String
  docpath              String
  workspaceId          Int
  metadata             String?
  pinned               Boolean?              @default(false)
  watched              Boolean?              @default(false)
  // "off" = RAG-only (default), "summary" = LLM summary always in context,
  // "full" = full text always in context (mirrors pinned=true behaviour)
  contextMode          String?               @default("off")
  createdAt            DateTime              @default(now())
  lastUpdatedAt        DateTime              @default(now())
  workspace            workspaces            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document_sync_queues document_sync_queues?

  @@index([workspaceId])
}

model invites {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  status        String   @default("pending")
  claimedBy     Int?
  workspaceIds  String?
  createdAt     DateTime @default(now())
  createdBy     Int
  lastUpdatedAt DateTime @default(now())
  claimedByUser users?   @relation(fields: [claimedBy], references: [id], onDelete: SetNull)

  @@index([claimedBy])
}

model system_settings {
  id            Int      @id @default(autoincrement())
  label         String   @unique
  value         String?
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @default(now())
}

// Phase 4: DB-backed replacement for the runtime-mutated `process.env` +
// `.env` dump anti-pattern. Persistent provider/application settings live here
// (encrypted at rest for sensitive keys) instead of being written back to disk.
model managed_env_settings {
  id            Int      @id @default(autoincrement())
  envKey        String   @unique
  value         String?
  encrypted     Boolean  @default(false)
  category      String?
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @default(now())
}

// Phase 4: Audit trail for every setting mutation. Values for sensitive keys
// are redacted so secrets are never persisted in plaintext to the log.
model settings_audit_log {
  id            Int      @id @default(autoincrement())
  envKey        String
  action        String   @default("update")
  previousValue String?
  newValue      String?
  redacted      Boolean  @default(false)
  userId        Int?
  createdAt     DateTime @default(now())

  @@index([envKey])
  @@index([userId])
  @@index([createdAt])
}

model users {
  id                           Int                           @id @default(autoincrement())
  username                     String?                       @unique
  password                     String
  pfpFilename                  String?
  role                         String                        @default("default")
  suspended                    Int                           @default(0)
  seen_recovery_codes          Boolean?                      @default(false)
  createdAt                    DateTime                      @default(now())
  lastUpdatedAt                DateTime                      @default(now())
  dailyMessageLimit            Int?
  dailyMessageUsedAt           Int?                          @default(0)
  dailyMessageResetAt          DateTime?
  bio                          String?                       @default("")
  web_push_subscription_config String?
  failed_login_count           Int?                          @default(0)
  failed_login_last_at         DateTime?
  workspace_chats              workspace_chats[]
  workspace_users              workspace_users[]
  embed_configs                embed_configs[]
  embed_chats                  embed_chats[]
  threads                      workspace_threads[]
  thread_folders               workspace_thread_folders[]
  recovery_codes               recovery_codes[]
  workspace_agent_invocations  workspace_agent_invocations[]
  slash_command_presets        slash_command_presets[]
  browser_extension_api_keys   browser_extension_api_keys[]
  temporary_auth_tokens        temporary_auth_tokens[]
  password_reset_tokens        password_reset_tokens[]
  system_prompt_variables      system_prompt_variables[]
  prompt_history               prompt_history[]
  desktop_mobile_devices       desktop_mobile_devices[]
  workspace_parsed_files       workspace_parsed_files[]
  memories                     memories[]
  api_keys                     api_keys[]
  invites                      invites[]
   event_logs                   event_logs[]
   model_routers                model_routers[]               @relation("RouterOwner")
   model_router_rules           model_router_rules[]          @relation("RuleOwner")
   artifacts                    workspace_artifacts[]

  @@index([failed_login_count])
  @@index([failed_login_last_at])
}

model recovery_codes {
  id        Int      @id @default(autoincrement())
  user_id   Int
  code_hash String
  createdAt DateTime @default(now())
  user      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model password_reset_tokens {
  id        Int      @id @default(autoincrement())
  user_id   Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model document_vectors {
  id            Int      @id @default(autoincrement())
  docId         String
  vectorId      String
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @default(now())

  @@index([docId])
}

model workspaces {
  id                           Int                            @id @default(autoincrement())
  name                         String
  slug                         String                         @unique
  vectorTag                    String?
  createdAt                    DateTime                       @default(now())
  openAiTemp                   Float?
  openAiHistory                Int                            @default(20)
  lastUpdatedAt                DateTime                       @default(now())
  // THIS IS THE SYSTEM PROMPT FOR THE WORKSPACE
  openAiPrompt                 String?
  similarityThreshold          Float?                         @default(0.25)
  chatProvider                 String?
  chatModel                    String?
  topN                         Int?                           @default(4)
  chatMode                     String?                        @default("chat")
  pfpFilename                  String?
  agentProvider                String?
  agentModel                   String?
  queryRefusalResponse         String?
  vectorSearchMode             String?                        @default("default")
  router_id                    Int?
  workspace_users              workspace_users[]
  workspace_chats              workspace_chats[]
  documents                    workspace_documents[]
  workspace_suggested_messages workspace_suggested_messages[]
  embed_configs                embed_configs[]
  threads                      workspace_threads[]
  thread_folders               workspace_thread_folders[]
  workspace_agent_invocations  workspace_agent_invocations[]
  prompt_history               prompt_history[]
  workspace_parsed_files       workspace_parsed_files[]
   memories                     memories[]
   notes                        workspace_notes[]
   artifacts                    workspace_artifacts[]

   @@index([router_id])
}

model workspace_threads {
  id                     Int                       @id @default(autoincrement())
  name                   String
  slug                   String                    @unique
  workspace_id           Int
  user_id                Int?
  folder_id              Int?
  createdAt              DateTime                  @default(now())
  lastUpdatedAt          DateTime                  @default(now())
  workspace              workspaces                @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user                   users?                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder                 workspace_thread_folders? @relation(fields: [folder_id], references: [id], onDelete: SetNull)
   workspace_parsed_files workspace_parsed_files[]
   artifacts              workspace_artifacts[]

   @@index([workspace_id])
   @@index([user_id])
   @@index([folder_id])
}

model workspace_thread_folders {
  id            Int                 @id @default(autoincrement())
  name          String
  workspace_id  Int
  user_id       Int?
  createdAt     DateTime            @default(now())
  lastUpdatedAt DateTime            @default(now())
  workspace     workspaces          @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user          users?              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  threads       workspace_threads[]

  @@index([workspace_id])
  @@index([user_id])
}

model workspace_suggested_messages {
  id            Int        @id @default(autoincrement())
  workspaceId   Int
  heading       String
  message       String
  createdAt     DateTime   @default(now())
  lastUpdatedAt DateTime   @default(now())
  workspace     workspaces @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model workspace_chats {
  id              Int        @id @default(autoincrement())
  workspaceId     Int
  prompt          String
  response        String
  include         Boolean    @default(true)
  user_id         Int?
  thread_id       Int?
  api_session_id  String? // String identifier for only the dev API to partition chats in any mode.
  createdAt       DateTime   @default(now())
  lastUpdatedAt   DateTime   @default(now())
  feedbackScore   Boolean?
  memoryProcessed Boolean?   @map("memory_processed")
   users           users?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
   workspace       workspaces @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
   artifacts       workspace_artifacts[]

   @@index([workspaceId])
  @@index([user_id])
  @@index([thread_id])
  @@index([workspaceId, thread_id])
  @@index([memoryProcessed])
  @@index([api_session_id])
}

model workspace_agent_invocations {
  id            Int        @id @default(autoincrement())
  uuid          String     @unique
  prompt        String // Contains agent invocation to parse + option additional text for seed.
  closed        Boolean    @default(false)
  user_id       Int?
  thread_id     Int? // No relation to prevent whole table migration
  workspace_id  Int
  createdAt     DateTime   @default(now())
  lastUpdatedAt DateTime   @default(now())
  user          users?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workspace     workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([workspace_id])
  @@index([user_id])
  @@index([thread_id])
}

model workspace_users {
  id            Int        @id @default(autoincrement())
  user_id       Int
  workspace_id  Int
  createdAt     DateTime   @default(now())
  lastUpdatedAt DateTime   @default(now())
  workspaces    workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  users         users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([user_id])
  @@index([workspace_id])
}

model cache_data {
  id            Int       @id @default(autoincrement())
  name          String
  data          String
  belongsTo     String?
  byId          Int?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  lastUpdatedAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([belongsTo])
}

model embed_configs {
  id                         Int           @id @default(autoincrement())
  uuid                       String        @unique
  enabled                    Boolean       @default(false)
  name                       String?
  chat_mode                  String        @default("query")
  allowlist_domains          String?
  allow_model_override       Boolean       @default(false)
  allow_temperature_override Boolean       @default(false)
  allow_prompt_override      Boolean       @default(false)
  max_chats_per_day          Int?
  max_chats_per_session      Int?
  message_limit              Int?          @default(20)
  workspace_id               Int
  createdBy                  Int?
  usersId                    Int?
  createdAt                  DateTime      @default(now())
  workspace                  workspaces    @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  embed_chats                embed_chats[]
  users                      users?        @relation(fields: [usersId], references: [id], onDelete: SetNull)

  @@index([workspace_id])
  @@index([usersId])
}

model embed_chats {
  id                     Int           @id @default(autoincrement())
  prompt                 String
  response               String
  session_id             String
  include                Boolean       @default(true)
  connection_information String?
  embed_id               Int
  usersId                Int?
  createdAt              DateTime      @default(now())
  embed_config           embed_configs @relation(fields: [embed_id], references: [id], onDelete: Cascade)
  users                  users?        @relation(fields: [usersId], references: [id], onDelete: SetNull)

  @@index([embed_id])
  @@index([usersId])
  @@index([session_id])
}

model event_logs {
  id         Int      @id @default(autoincrement())
  event      String
  metadata   String?
  userId     Int?
  occurredAt DateTime @default(now())
  user       users?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event])
  @@index([userId])
  @@index([occurredAt])
}

model slash_command_presets {
  id            Int      @id @default(autoincrement())
  command       String
  prompt        String
  description   String
  uid           Int      @default(0) // 0 is null user
  userId        Int?
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @default(now())
  user          users?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([uid, command])
  @@index([userId])
}

model document_sync_queues {
  id             Int                        @id @default(autoincrement())
  staleAfterMs   Int                        @default(604800000) // 7 days
  nextSyncAt     DateTime
  createdAt      DateTime                   @default(now())
  lastSyncedAt   DateTime                   @default(now())
  workspaceDocId Int                        @unique
  workspaceDoc   workspace_documents?       @relation(fields: [workspaceDocId], references: [id], onDelete: Cascade)
  runs           document_sync_executions[]

  @@index([nextSyncAt])
}

model document_sync_executions {
  id        Int                  @id @default(autoincrement())
  queueId   Int
  status    String               @default("unknown")
  result    String?
  createdAt DateTime             @default(now())
  queue     document_sync_queues @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])
}

model browser_extension_api_keys {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  user_id       Int?
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @updatedAt
  user          users?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model temporary_auth_tokens {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model system_prompt_variables {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String?
  description String?
  type        String   @default("system") // system, user, dynamic
  userId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        users?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model prompt_history {
  id          Int        @id @default(autoincrement())
  workspace   workspaces @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId Int
  prompt      String
  modifiedBy  Int?
  modifiedAt  DateTime   @default(now())
  user        users?     @relation(fields: [modifiedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([modifiedBy])
}

// Schema specific to mobile app <> Desktop app connection
model desktop_mobile_devices {
  id         Int      @id @default(autoincrement())
  deviceOs   String
  deviceName String
  token      String   @unique
  approved   Boolean  @default(false)
  userId     Int?
  createdAt  DateTime @default(now())
  user       users?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model workspace_parsed_files {
  id                 Int                @id @default(autoincrement())
  filename           String             @unique
  workspaceId        Int
  userId             Int?
  threadId           Int?
  metadata           String?
  tokenCountEstimate Int?               @default(0)
  createdAt          DateTime           @default(now())
  workspace          workspaces         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               users?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread             workspace_threads? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([threadId])
}

model external_communication_connectors {
  id            Int      @id @default(autoincrement())
  type          String   @unique
  config        String   @default("{}")
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @default(now())
}

model scheduled_jobs {
  id        Int                  @id @default(autoincrement())
  name      String
  prompt    String
  tools     String? // JSON array of tool identifiers (null = use all enabled agent skills)
  schedule  String // Cron expression
  enabled   Boolean              @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  runs      scheduled_job_runs[]

  @@index([enabled, nextRunAt])
}

model scheduled_job_runs {
  id          Int            @id @default(autoincrement())
  jobId       Int
  status      String         @default("queued") // queued | running | completed | failed | timed_out — model always sets explicitly
  result      String? // JSON execution trace
  error       String?
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  readAt      DateTime? // null = unread
  job         scheduled_jobs @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
}

model politicians {
  id                String    @id // UUID
  externalId        String?   @unique // Bundestag-ID or Abgeordnetenwatch-ID
  source            String    @default("bundestag") // bundestag | abgeordnetenwatch
  title             String? // Dr., Prof. Dr., etc.
  firstName         String
  lastName          String
  fullName          String
  party             String? // current party
  faction           String? // current faction
  gender            String?
  birthDate         DateTime?
  birthPlace        String?
  deathDate         DateTime?
  profession        String?
  education         String?
  religion          String?
  familyStatus      String?
  photoUrl          String?
  websiteUrl        String?
  email             String?
  twitterHandle     String?
  facebookUrl       String?
  linkedinUrl       String?
  instagramUrl      String?
  youtubeUrl        String?
  tiktokUrl         String?
  bio               String? // full biography text
  profileUrl        String? // link to Bundestag profile
  electoralDistrict String? // Wahlkreis
  electoralList     String? // Landesliste
  state             String? // Bundesland
  rawData           String? // JSON blob of raw API response
  lastSyncedAt      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  mandates             politician_mandates[]
  votes                politician_votes[]
  speeches             politician_speeches[]
  committeeMemberships politician_committee_memberships[]

  @@index([source])
  @@index([lastName])
  @@index([party])
  @@index([state])
}

model politician_mandates {
  id                String    @id @default(uuid())
  politicianId      String
  type              String    @default("bundestag") // bundestag | landtag | europaparlament | minister
  position          String? // Abgeordneter, Minister, Staatssekretaer, etc.
  party             String?
  faction           String?
  electoralDistrict String? // Wahlkreis
  state             String?
  startDate         DateTime?
  endDate           DateTime?
  info              String? // committee membership summary
  rawData           String? // JSON blob
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  politician politicians @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  @@index([politicianId])
  @@index([type])
}

model politician_votes {
  id                 String    @id @default(uuid())
  politicianId       String
  session            Int? // Wahlperiode
  sitting            Int? // Sitzungsnummer
  voteId             String? // external vote ID
  voteTitle          String? // Beschlusstext Kurzfassung
  voteDescription    String? // full description
  voteResult         String? // Ja / Nein / Enthaltung / Nicht abgestimmt
  voteDate           DateTime?
  documentUrl        String? // Link to Drucksache
  plenaryProtocolUrl String? // Link to Plenarprotokoll
  rawData            String? // JSON blob
  createdAt          DateTime  @default(now())

  politician politicians @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  @@index([politicianId])
  @@index([session])
  @@index([voteDate])
}

model politician_speeches {
  id              String    @id @default(uuid())
  dedupeKey       String?   @unique // session/sitting/speaker/text hash for idempotent sync
  politicianId    String
  speakerName     String? // extracted from Plenarprotokoll
  speakerParty    String? // faction/party at time of speech
  session         Int? // Wahlperiode
  sitting         Int? // Sitzungsnummer
  speechTitle     String? // TOP description
  speechText      String // full speech text
  speechDate      DateTime?
  documentUrl     String? // Link to Plenarprotokoll
  pageNumbers     String? // e.g. "1234-1236"
  rawData         String? // JSON blob
  matchConfidence Float? // 0..1 speaker matching confidence
  vectorized      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt

  politician politicians @relation(fields: [politicianId], references: [id], onDelete: Cascade)

  @@index([politicianId])
  @@index([speechDate])
  @@index([vectorized])
  @@index([dedupeKey])
}

model politician_committees {
  id          String   @id @default(uuid())
  name        String   @unique
  fullName    String?
  type        String? // Ausschuss | Unterausschuss | Enquete | etc.
  description String?
  createdAt   DateTime @default(now())

  members politician_committee_memberships[]
}

model politician_committee_memberships {
  id           String    @id @default(uuid())
  politicianId String
  committeeId  String
  role         String? // Mitglied | Vorsitzender | Stellv. Vorsitzender | etc.
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())

  politician politicians           @relation(fields: [politicianId], references: [id], onDelete: Cascade)
  committee  politician_committees @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@unique([politicianId, committeeId])
  @@index([committeeId])
}

model politician_sync_log {
  id             Int       @id @default(autoincrement())
  source         String // bundestag | abgeordnetenwatch | plenarprotokolle
  status         String    @default("started") // started | running | completed | failed
  itemsTotal     Int       @default(0)
  itemsProcessed Int       @default(0)
  itemsFailed    Int       @default(0)
  error          String?
  details        String? // JSON metadata
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([source])
  @@index([status])
  @@index([startedAt])
}

// Retry queue for failed sync phases (Issue #52). When a phase fails it is
// enqueued here with an exponential back-off `nextRetryAt`. The sync job drains
// due entries at the start of each run. A unique `phase` keeps a single live
// entry per phase (members | abgeordnetenwatch | speeches).
model politician_sync_retry {
  id          Int      @id @default(autoincrement())
  phase       String   @unique // members | abgeordnetenwatch | speeches
  attempts    Int      @default(0)
  status      String   @default("pending") // pending | exhausted | resolved
  lastError   String?
  nextRetryAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, nextRetryAt])
}

model memories {
  id          Int                          @id @default(autoincrement())
  userId      Int?                         @map("user_id")
  workspaceId Int?                         @map("workspace_id")
  scope       String                       @default("workspace")
  content     String
  // Semantic embedding for vector similarity search via pgvector.
  // Dimension matches the default embedding model (text-embedding-3-small = 1536).
  // Set to null until the memory is first embedded.
  embedding   Unsupported("vector(1536)")?
  lastUsedAt  DateTime?                    @map("last_used_at")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @default(now()) @map("updated_at")

  user      users?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace workspaces? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@index([userId, scope])
  @@index([workspaceId])
}

model model_routers {
  id                Int                  @id @default(autoincrement())
  name              String               @unique
  description       String?
  fallback_provider String
  fallback_model    String
  cooldown_seconds  Int                  @default(30)
  created_by        Int?
  createdAt         DateTime             @default(now())
  lastUpdatedAt     DateTime             @default(now())
  createdByUser     users?               @relation("RouterOwner", fields: [created_by], references: [id], onDelete: SetNull)
  rules             model_router_rules[]

  @@index([created_by])
}

model model_router_rules {
  id              Int           @id @default(autoincrement())
  router_id       Int
  enabled         Boolean       @default(true)
  priority        Int
  type            String        @default("calculated")
  title           String
  description     String?
  // For `calculated` rules: the boolean operator joining `conditions` — "AND"
  // (all must match) or "OR" (any must match). Null for `llm` rules.
  condition_logic String?
  // For `calculated` rules: JSON-stringified array of condition objects, each
  // shaped as { property: string, comparator: string, value: string } where
  // `property` ∈ VALID_PROPERTIES and `comparator` ∈ VALID_COMPARATORS (see
  // server/models/modelRouterRule.js). `value` is always stored as a string;
  // numeric comparators parse it at evaluation time. Null for `llm` rules.
  conditions      String?
  route_provider  String
  route_model     String
  created_by      Int?
  createdAt       DateTime      @default(now())
  lastUpdatedAt   DateTime      @default(now())
  createdByUser   users?        @relation("RuleOwner", fields: [created_by], references: [id], onDelete: SetNull)
  router          model_routers @relation(fields: [router_id], references: [id], onDelete: Cascade)

  @@unique([router_id, title])
  @@index([router_id])
  @@index([router_id, enabled, priority])
  @@index([created_by])
}

// Persistente Background-Job Queue
// Überlebt Server-Restarts, Mac-Sleep und Docker-Neustarts (Jobs liegen in SQLite).
// Gemanaged von `server/utils/backgroundJobs/queue.js`.
model job_queue {
  id           Int       @id @default(autoincrement())
  job_name     String
  payload      String // JSON-serialisiert; nur IDs/Slugs/Strings, keine Prisma-Objekte!
  status       String    @default("pending") // pending | processing | completed | failed
  attempts     Int       @default(0)
  max_attempts Int       @default(3)
  last_error   String?
  locked_at    DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([status, created_at])
  @@index([status, locked_at])
}

model workspace_notes {
  id          Int        @id @default(autoincrement())
  workspaceId Int
  title       String     @default("")
  content     String     @default("")
  plainText   String     @default("")
  tags        String     @default("[]")
  folder      String?
  pinned      Boolean?   @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now())
  workspace   workspaces @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, deletedAt])
}

// Shared workspace notes — replaces the raw CREATE TABLE IF NOT EXISTS
// that was in workspaceNote.js. Now managed via Prisma migrations.
model shared_workspace_notes {
  id                 String   @id
  note_id            Int
  target_workspace_id Int
  shared_by          Int?
  shared_at          Int

  @@unique([note_id, target_workspace_id])
  @@index([note_id])
  @@index([target_workspace_id])
}

// Persistent store for async PDF/file parse jobs.
// Replaces the previous in-memory Map so jobs survive server restarts.
// Managed by `server/utils/parseJobs/index.js`.
model parse_jobs {
  // UUID generated in application code (not autoincrement) so the id can be
  // handed to the client *before* the row is committed.
  id          String    @id
  workspaceId Int
  userId      Int?
  originalname String
  // pending | processing | completed | failed
  status      String    @default("pending")
  // JSON array of WorkspaceParsedFiles rows; null until completed.
  files       String?
  error       String?
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([workspaceId, status])
  @@index([createdAt])
}

// Feature: Transformations — LLM-powered document analysis templates.
// Each transformation holds a reusable prompt; running it on a document
// produces a document_insight stored below.
model transformations {
  id            Int                  @id @default(autoincrement())
  name          String
  title         String
  description   String?
  prompt        String
  applyDefault  Boolean              @default(false)
  createdAt     DateTime             @default(now())
  lastUpdatedAt DateTime             @default(now())
  insights      document_insights[]
}

// Feature: Document Insights — results of running a transformation against
// a workspace document. Keyed by docId (workspace_documents.docId) and
// workspaceId so they survive document re-pins without foreign-key issues.
model document_insights {
  id               Int             @id @default(autoincrement())
  docId            String
  workspaceId      Int
  transformationId Int
  title            String
  content          String
  createdAt        DateTime        @default(now())
  transformation   transformations @relation(fields: [transformationId], references: [id], onDelete: Cascade)

  @@index([docId])
  @@index([workspaceId])
}

// Agent run lifecycle — persists run state for reconnect-safe SSE.
// Created by subagentSpawner; read by agentRunsStream on reconnect.
// Status values: running | waiting_input | queued | done | error | cancelled
model agent_runs {
  id            String    @id
  workspace_id  Int
  parent_run_id String?
  agent_name    String
  model         String?
  status        String    @default("running")
  turn_id       String?
  started_at    DateTime  @default(now())
  ended_at      DateTime?

  @@index([workspace_id, status])
  @@index([started_at])
  @@index([turn_id])
}

// Agent trigger definitions — schedule and polling triggers per workspace.
// Type values: schedule | polling
model agent_triggers {
  id           String    @id
  workspace_id Int
  agent_name   String
  name         String
  type         String
  config       String    // JSON string
  active       Boolean   @default(true)
  checkpoint   String?   // JSON string
  last_run_at  DateTime?
  next_run_at  DateTime?
  created_at   DateTime  @default(now())

  @@index([workspace_id])
  @@index([active, next_run_at])
}

// Trigger run history with idempotency via dedupe_key.
// Status values: queued | running | done | error
model trigger_runs {
  id            String    @id
  trigger_id    String
  status        String    @default("queued")
  dedupe_key    String?
  attempt       Int       @default(0)
  error_message String?
  result        String?   // JSON string
  started_at    DateTime?
  ended_at      DateTime?
  created_at    DateTime  @default(now())

  @@index([trigger_id, created_at])
  @@index([dedupe_key, status])
}

// OAuth connector accounts with AES-GCM-encrypted tokens.
// Composite unique key prevents duplicate connections per user+provider+account.
model connector_accounts {
  id                Int       @id @default(autoincrement())
  user_id           Int       @default(0)
  provider          String
  provider_account  String    @default("")
  scopes            String?
  access_token_enc  String
  refresh_token_enc String?
  token_type        String    @default("Bearer")
  expires_at        DateTime?
  last_refresh_at   DateTime?
  status            String    @default("active")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  @@unique([user_id, provider, provider_account])
  @@index([user_id])
  @@index([status])
}

model workspace_artifacts {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique
  workspaceId  Int
  threadId     Int?
  chatId       Int?
  userId       Int?
  turnId       String?
  type         String
  status       String   @default("ready")
  title        String
  description  String?
  mimeType     String?
  storagePath  String?
  downloadName String?
  content      String?
  metadata     String?
  sourceData   String?
  version      Int      @default(1)
  parentUuid   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace workspaces         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  thread    workspace_threads? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  chat      workspace_chats?   @relation(fields: [chatId], references: [id], onDelete: SetNull)
  user      users?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, type])
  @@index([threadId])
  @@index([chatId])
  @@index([turnId])
  @@index([parentUuid])
}
