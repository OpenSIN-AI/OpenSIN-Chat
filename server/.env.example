FIREWORKS_AI_LLM_API_KEY='replace-with-your-provider-key'
FIREWORKS_AI_LLM_BASE_PATH='https://your-router.example.com/inference/v1'
FIREWORKS_AI_LLM_MODEL_PREF='accounts/fireworks/models/your-model'
FIREWORKS_AI_LLM_MODEL_TOKEN_LIMIT=256000

