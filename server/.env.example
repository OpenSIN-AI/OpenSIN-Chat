SERVER_PORT=3001

# ============================================================
# PFLICHT-SECRETS — vor dem ersten Start ausfüllen!
# Niemals die Beispielwerte produktiv lassen.
#   JWT_SECRET: openssl rand -hex 24
#   SIG_KEY:    openssl rand -hex 32   (>= 32 Zeichen)
#   SIG_SALT:   openssl rand -hex 16   (>= 32 Zeichen)
# WICHTIG: SIG_KEY/SIG_SALT verschlüsseln gespeicherte Provider-API-Keys.
#          Werden sie nachträglich geändert, müssen alle Keys in der UI
#          neu eingetragen werden.
# ============================================================
JWT_SECRET=
SIG_KEY=
SIG_SALT=

# Single-user access password. Required for production single-user deployments
# by default. Multi-user deployments authenticate with their user accounts.
# Use a long random value and keep it outside version control.
AUTH_TOKEN=
# Only for deliberately public/trusted deployments with no login at all:
# ALLOW_UNAUTHENTICATED_SINGLE_USER="false"

# JWT token lifetime (default: 15m). Examples: "15m", "1h", "7d".
# JWT_EXPIRY=15m

# Maximum JSON/text/form request body. File uploads have separate limits.
# BODY_LIMIT="10mb"

# ============================================================
# SECURITY HEADERS
# ============================================================
# Enable HSTS (Strict-Transport-Security) once TLS is confirmed.
# Only set to "true" behind a working HTTPS/TLS termination.
# Setting this on plain HTTP is harmless but misleading.
# ENABLE_HSTS="true"
#
# CSP Report-Only mode: set to "true" to measure CSP violations
# without blocking anything. Useful for safe rollout of new CSP rules.
# CSP_REPORT_ONLY="false"
#
# Full COOP/COEP cross-origin isolation is disabled by default because it can
# break OAuth popups, external images/workers, and the public embed widget.
# Enable only when SharedArrayBuffer-style isolation is explicitly required.
# ENABLE_CROSS_ORIGIN_ISOLATION="false"
#
# Comma-separated list of allowed CORS origins. NEVER use "*".
# Example: CORS_ORIGIN="https://chat.opensin.ai,https://admin.opensin.ai"
# CORS_ORIGIN=""
#
# Trust proxy setting for Express (controls X-Forwarded-For handling).
# Set to your reverse proxy IP(s) in production.
# Examples: "loopback" (default), "10.0.0.1", "10.0.0.1,10.0.0.2"
# TRUST_PROXY="loopback"

###########################################
######## DATABASE (PostgreSQL) ############
###########################################
# Required. Points to the PostgreSQL instance (Supabase self-hosted or any PostgreSQL provider).
# Replace <password> and <host> with your actual values.
# DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres"
#
# pgvector — set VECTOR_DB=pgvector below and use the same connection string.
# PGVECTOR_CONNECTION_STRING="postgresql://postgres:<password>@<host>:5432/postgres"
# PGVECTOR_TABLE_NAME="opensin_vectors"
#
# DATABASE_TYPE controls PostgreSQL-specific features (e.g. native vector columns).
# Set to "postgres" when using PostgreSQL; leave unset for SQLite (dev default).
# DATABASE_TYPE=postgres

###########################################
######## SUPABASE STORAGE #################
###########################################
# Enable Supabase Storage to persist uploads (required on Vercel / stateless deploys).
# When disabled the server falls back to the local filesystem.
#
# SUPABASE_STORAGE_ENABLED="true"
# SUPABASE_STORAGE_URL="http://localhost:8000/storage/v1"
# SUPABASE_SERVICE_KEY="<your-supabase-service_role-key>"
#
# Optional bucket name overrides (defaults shown):
# SUPABASE_STORAGE_BUCKET_DOCUMENTS="documents"
# SUPABASE_STORAGE_BUCKET_REPORTS="reports"
# SUPABASE_STORAGE_BUCKET_AVATARS="avatars"
# SUPABASE_STORAGE_BUCKET_ASSETS="assets"

###########################################
######## LLM API SElECTION ################
###########################################
