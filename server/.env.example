#------ Bing Search ----------- https://portal.azure.com/
# AGENT_BING_SEARCH_API_KEY=

#------ Baidu Search ----------- https://cloud.baidu.com/doc/qianfan-api/s/Wmbq4z7e5
# AGENT_BAIDU_SEARCH_API_KEY=

#------ Serply.io ----------- https://serply.io/
# AGENT_SERPLY_API_KEY=

#------ SearXNG ----------- https://github.com/searxng/searxng
# AGENT_SEARXNG_API_URL=

#------ Vane (Self-Hosted AI Answer Engine) ----------- https://github.com/ItzCrazyKns/Vane
# URL of the Vane sidecar (default: Docker-internal DNS when using docker-compose).
# The bundled Vane image also exposes SearxNG internally on port 8080 if needed.
VANE_API_URL=http://vane:8300
# Externer Port: 8310 (container-intern 8300)
# VANE_CHAT_PROVIDER_URL=http://host.docker.internal:11434/v1 (Ollama)
# Falls Vane alleinstehend: http://localhost:8310

# Optional: explicit model selection (else auto-discovery via /api/providers)
# VANE_CHAT_PROVIDER_ID=
# VANE_CHAT_MODEL_KEY=gpt-4o-mini
# VANE_EMBED_PROVIDER_ID=
# VANE_EMBED_MODEL_KEY=text-embedding-3-large

#------ Tavily ----------- https://www.tavily.com/
# AGENT_TAVILY_API_KEY=

#------ Exa Search ----------- https://www.exa.ai/
# AGENT_EXA_API_KEY=

#------ Perplexity Search ----------- [https://console.perplexity.ai](https://console.perplexity.ai)
# AGENT_PERPLEXITY_API_KEY=

###########################################
######## Other Configurations ############
###########################################

# Disable viewing chat history from the UI and frontend APIs.
# See https://docs.opensin.delqhi.com/configuration#disable-view-chat-history for more information.
# DISABLE_VIEW_CHAT_HISTORY=1

# Disable workspace deletion from the UI and APIs when this ENV is present with any value.
# WORKSPACE_DELETION_PROTECTION=1

# Enable simple SSO passthrough to pre-authenticate users from a third party service.
# See https://docs.opensin.delqhi.com/configuration#simple-sso-passthrough for more information.
# SIMPLE_SSO_ENABLED=1
# SIMPLE_SSO_NO_LOGIN=1
# SIMPLE_SSO_NO_LOGIN_REDIRECT=https://your-custom-login-url.com (optional)

# Allow scraping of any IP address in collector - must be string "true" to be enabled
# See https://docs.opensin.delqhi.com/configuration#local-ip-address-scraping for more information.
# COLLECTOR_ALLOW_ANY_IP="true"

# Port the collector listens on. Must match the collector process when running services separately.
# COLLECTOR_PORT=8888

# Specify the target languages for when using OCR to parse images and PDFs.
# This is a comma separated list of language codes as a string. Unsupported languages will be ignored.
# Default is English. See https://tesseract-ocr.github.io/tessdoc/Data-Files-in-different-versions.html for a list of valid language codes.
# TARGET_OCR_LANG=eng,deu,ita,spa,fra,por,rus,nld,tur,hun,pol,ita,spa,fra,por,rus,nld,tur,hun,pol

# Runtime flags for built-in pupeeteer Chromium instance
# This is only required on Linux machines running AnythingLLM via Docker
# and do not want to use the --cap-add=SYS_ADMIN docker argument
# OPENSIN_CHROMIUM_ARGS="--no-sandbox,--disable-setuid-sandbox"
# ANYTHINGLLM_CHROMIUM_ARGS=...  (deprecated, use OPENSIN_CHROMIUM_ARGS)

# This enables HTTP request/response logging in development. Set value to a truthy string to enable, leave empty value or comment out to disable.
# ENABLE_HTTP_LOGGER=""
# This enables timestamps for the HTTP Logger. Set value to a truthy string to enable, leave empty value or comment out to disable.
# ENABLE_HTTP_LOGGER_TIMESTAMPS=""

# Disable Swagger API documentation endpoint.
# Set to "true" to disable the /api/docs endpoint (recommended for production deployments).
# DISABLE_SWAGGER_DOCS="true"

# Disable MCP cooldown timer for agent calls
# this can lead to infinite recursive calls of the same function
# for some model/provider combinations
# MCP_NO_COOLDOWN="true"

# Allow native tool calling for specific providers.
# This can VASTLY improve performance and speed of agent calls.
# Check code for supported providers who can be enabled here via this flag
# PROVIDER_SUPPORTS_NATIVE_TOOL_CALLING="generic-openai,bedrock,localai,groq,litellm,openrouter"

# (optional) Maximum number of tools an agent can chain for a single response.
# This prevents some lower-end models from infinite recursive tool calls.
# AGENT_MAX_TOOL_CALLS=10

# Enable agent tool reranking to reduce token usage by selecting only the most relevant tools
# for each query. Uses the native embedding reranker to score tools against the user's prompt.
# Set to "true" to enable. This can reduce token costs by 80% when you have
# many tools/MCP servers enabled.
# AGENT_SKILL_RERANKER_ENABLED="true"
# AGENT_SKILL_RERANKER_TOP_N=15 # (optional) Number of top tools to keep after reranking (default: 15)

# (optional) Memory extraction background job settings.
# MEMORY_EXTRACTION_INTERVAL="15m" # How often the extraction job runs (default: 15m)
# MEMORY_IDLE_THRESHOLD_MS=1200000 # Min ms since last chat before extraction runs (default: 1200000 / 20min). Set to 0 to disable the idle check.

# (optional) Maximum number of scheduled jobs that can run concurrently.
# Default is 1. Increase if using a cloud LLM provider with high rate limits.
# SCHEDULED_JOB_MAX_CONCURRENT=1

# (optional) Maximum time in milliseconds a scheduled job can run before being terminated.
# Default is 5 minutes (300000ms).
# SCHEDULED_JOB_TIMEOUT_MS=300000

# (optional) Comma-separated list of skills that are auto-approved.
# This will allow the skill to be invoked without user interaction.
# AGENT_AUTO_APPROVED_SKILLS=create-pdf-file,create-word-file

# (optional) How long (in milliseconds) a watched document waits before it is
# re-synced by the document sync background worker.
# Default is 7 days (604800000ms). A minimum of 1 hour (3600000ms) is enforced.
# DOCUMENT_SYNC_STALE_AFTER_MS=604800000

###########################################
######## POLITICIAN DATA SYNC #############
###########################################
# Configuration for the politician data sync job which pulls members of the
# German Bundestag from the Abgeordnetenwatch and Bundestag (DIP) APIs.

# (optional) DIP API key for search.dip.bundestag.de — used by the politician
# sync job, plenarprotocol scraper, and the /utils/bundestag/drucksachen proxy.
# A public demo key is hardcoded as fallback; set your own key to avoid
# rate-limiting. Legacy env var names DIP_API_KEY and BUNDESTAG_API_KEY are
# also accepted as fallbacks.
# BUNDESTAG_DIP_API_KEY=

# (optional) Abgeordnetenwatch parliament period ID used to fetch the current
# set of MPs. Default is 132 (Bundestag, 21. Wahlperiode / 2025–).
# AW_PARLIAMENT_PERIOD=132

# (optional) Bundestag electoral term (Wahlperiode) used by the Bundestag/DIP
# API client and the politician sync job. The formular endpoint falls back to
# the DIP API when the term-specific endpoint is unavailable.
# Default is 21 (21. Wahlperiode / 2025–).
# BUNDESTAG_WAHLPERIODE=21

# (optional) Enable Abgeordnetenwatch enrichment (committee memberships, votes,
# social links) for synced politicians. Set to "true" to enable. Default false.
# AW_ENRICH_POLITICIANS=false

# (optional) Maximum number of parliamentary sittings processed per sync run.
# Keeps each run bounded so it does not exceed the scheduled job timeout.
# Default is 5.
# POLITICIAN_SYNC_SITTINGS_PER_RUN=5

###########################################
######## RESEARCH PIPELINE LIMITS #########
###########################################
# BoundedJobStore limits for the ResearchPipeline and AgentOrchestrator.
# These prevent memory-DoS from unbounded job accumulation.
#
# --- Research Pipeline ---
# RESEARCH_MAX_JOBS=100      # Total concurrent research jobs across all users
# RESEARCH_MAX_ACTIVE=10     # Simultaneously running (pending/running) jobs
# RESEARCH_TTL_MINUTES=30    # How long completed/failed jobs stay in memory
#
# --- Agent Orchestrator ---
# ORCHESTRATOR_MAX_WORKFLOWS=50  # Total concurrent workflows
# ORCHESTRATOR_MAX_ACTIVE=5      # Simultaneously running workflows
# ORCHESTRATOR_TTL_MINUTES=30    # How long completed/failed workflows stay
#
# --- Content Extractor SSRF ---
# RESEARCH_ALLOW_PRIVATE_NETWORKS="false"  # Set "true" to allow private IPs
# RESEARCH_STRICT_SSRF="false"             # Set "true" for DNS-resolution private-IP checks

###########################################
########## Rate Limits / Reports ##########
###########################################
# In-Memory-Rate-Limiting für teure API-Endpoints (429 bei Überschreitung)
# DISABLE_RATE_LIMITS=false      # true = alle Limits deaktivieren (nur Dev/Tests)

# Disk-Fill-Schutz für generierte PDF-Berichte
# REPORTS_MAX_FILES=100          # max. Anzahl PDFs in storage/generated-reports
# REPORTS_MAX_AGE_DAYS=30        # PDFs älter als N Tage werden gelöscht

###########################################
########## PDF Analysis ###################
###########################################
# PDF-Analyse-Modul: Multi-Agenten-Pipeline für große PDFs.
# Alle Werte sind optional mit defensiven Defaults.
#
# PDF_ANALYSIS_MAX_ACTIVE_JOBS=2        # Max. gleichzeitig laufende Analyse-Jobs
# PDF_ANALYSIS_CONCURRENCY=6            # Parallele Agenten pro Job (AIMD-Start)
# PDF_ANALYSIS_CORPUS_CONCURRENCY=4     # Max. parallele Dokumente in einem Korpus-Job
# PDF_ANALYSIS_PAGES_PER_CHUNK=8       # Seiten pro Analyse-Chunk
# PDF_ANALYSIS_OVERLAP_PAGES=1         # Überlappung zwischen Chunks
# PDF_ANALYSIS_MAX_PAGES=0             # 0 = unbegrenzt
# PDF_ANALYSIS_TEMPERATURE=0           # LLM-Temperatur
# PDF_ANALYSIS_MAX_CHARS_PER_CHUNK=24000
# PDF_ANALYSIS_FACT_MIN_CONF=0.7       # Mindest-Konfidenz für Fakten-Speicherung
#
# --- OCR / Vision ---
# PDF_ANALYSIS_OCR=true                # OCR-Fallback für gescannte PDFs
# PDF_ANALYSIS_OCR_LANGS=deu+eng       # Tesseract-Sprachen (Fallback-Kette: deu+eng → deu → eng → none)
# PDF_ANALYSIS_OCR_SCALE=2.0           # Render-Skalierung für OCR
# PDF_ANALYSIS_OCR_MIN_CHARS=16        # Unter dieser Zeichenzahl gilt Seite als "ohne Text-Layer"
# PDF_ANALYSIS_VISION_BACKEND=auto     # auto | ollama | cloud
# PDF_ANALYSIS_OLLAMA_URL=http://localhost:11434
# PDF_ANALYSIS_OLLAMA_VISION_MODEL=minicpm-v
# PDF_ANALYSIS_OLLAMA_TIMEOUT_MS=180000
# PDF_ANALYSIS_OLLAMA_NUM_CTX=8192
# PDF_ANALYSIS_DEEPSCAN_SCALE=2.0
#
# --- Retention / Cleanup ---
# PDF_ANALYSIS_UPLOAD_TTL_DAYS=7       # Uploads löschen nach N Tagen (wenn nicht referenziert)
# PDF_ANALYSIS_REPORT_TTL_DAYS=0       # 0 = Reports nie löschen
# PDF_ANALYSIS_JOB_TTL_DAYS=30         # Abgeschlossene Job-Snapshots nach N Tagen löschen
# PDF_ANALYSIS_CLEANUP_INTERVAL_MS=3600000  # Cleanup-Intervall (Default 1h)
# PDF_ANALYSIS_JOB_TIMEOUT_MINUTES=30  # Running-Jobs nach N Min als "stuck" markieren

###########################################
########## Server Hardening ##############
###########################################
# Body-Parser-Limit für JSON- und URL-encoded Requests (Default: 50mb).
# Datei-Uploads verwenden separate, endpoint-spezifische Limits. Nur erhöhen,
# wenn ein konkreter API-Use-Case dies benötigt:
# BODY_LIMIT=50mb

# Express trust proxy (Default: loopback). Auf die konkrete Proxy-Adresse oder
# eine passende Express-Trust-Proxy-Regel setzen; niemals pauschal alle Proxies
# vertrauen, wenn die Anwendung direkt exponiert ist:
# TRUST_PROXY=loopback

# Telemetry deaktivieren (Default: false). OpenSIN-Chat hat Telemetrie bereits
# standardmäßig deaktiviert (kein PostHog, kein Mintplex CDN); dies ist ein
# zusätzlicher Schalter für die verbleibenden internen Event-Logs.
# DISABLE_TELEMETRY=true

###########################################
########## HTTP Security Headers ##########
###########################################
# HSTS erst aktivieren, wenn TLS-Terminierung stabil läuft (180 Tage max-age):
# ENABLE_HSTS=true

# CSP im Report-Only-Modus ausliefern (Violations im Browser-DevTools/Reporting
# messen, BEVOR eine enforced CSP gesetzt wird — SPA nutzt WASM/Worker/Inline-Styles):
# CSP_REPORT_ONLY=true

# Deployment-Verifikation (werden vom Docker-Build gesetzt, siehe Dockerfile):
# APP_VERSION=v0.5.0
# GIT_SHA=da79254

###########################################
########## Structured Logging #############
###########################################
# Used by the structured logger (server/utils/logger/structured.js).
#
# Minimum level that is emitted. Entries below this threshold are dropped.
# One of: debug | info | warn | error. Default: info.
# LOG_LEVEL=info
#
# Output format. Set to "json" for machine-readable, one-line-per-entry logs
# suitable for log aggregation (Loki, Datadog, CloudWatch, etc.). Any other
# value produces human-readable, colorized console output. Default: text.
# LOG_FORMAT=json

