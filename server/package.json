{
  "name": "opensin-chat-server",
  "version": "1.14.0",
  "description": "Server endpoints to process or create content for chatting",
  "main": "index.js",
  "author": "OpenSIN-AI",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
