# Placeholder .env file for collector runtime

# Port the collector listens on. The server must use the same COLLECTOR_PORT value when running services separately.
# COLLECTOR_PORT=8888

# Root storage directory for documents, uploads, and tmp files.
# In Docker this is typically /app/server/storage.
# In development it falls back to <repo>/server/storage if unset.
# STORAGE_DIR=/app/server/storage

# This enables HTTP request/response logging in development. Set value to truthy string to enable, leave empty value or comment out to disable
# ENABLE_HTTP_LOGGER=""
# This enables timestamps for the HTTP Logger. Set value to true to enable, leave empty or comment out to disable
# ENABLE_HTTP_LOGGER_TIMESTAMPS=""

###########################################
########## OCR (PDF TEXT EXTRACTION) ######
###########################################
# OCR engine to use for image-heavy or scanned PDFs. Supported values: "nim" (default), "tesseract".
# OCR_ENGINE=nim

# Timeout (ms) for OCR processing a single PDF page. Default: 600000 (10 min).
# OCR_TIMEOUT_MS=600000

# Bootstrap timeout (ms) for the OCR worker process before it is killed. Default: 30000.
# OCR_WORKER_BOOTSTRAP_TIMEOUT_MS=30000

# Ratio (0.0–1.0) of pages that must return OCR text before the result replaces the native PDF text layer.
# A higher value makes OCR less aggressive. Default: 0.5
# PDF_OCR_MERGE_RATIO=0.5

# --- Tesseract (OCR_ENGINE=tesseract) ---
# Path to the Tesseract binary. Default: system PATH lookup.
# OCR_CORE_PATH=/usr/bin/tesseract
# Path to Tesseract language data files (.traineddata).
# OCR_TESSDATA_PATH=/usr/share/tesseract-ocr/5/tessdata

# --- NVIDIA NIM (OCR_ENGINE=nim) ---
# NIM API base URL. Default: https://integrate.api.nvidia.com/v1
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM model for OCR. Default: nvidia/llama-3.2-11b-vision-instruct
# NVIDIA_NIM_MODEL=nvidia/llama-3.2-11b-vision-instruct
# NIM API key. Required when using the NIM OCR engine.
# NVIDIA_NIM_API_KEY=
# Maximum tokens to request per NIM completion. Default: 4096
# NVIDIA_NIM_MAX_TOKENS=4096
# Request timeout (ms) per NIM call. Default: 120000
# NVIDIA_NIM_TIMEOUT_MS=120000
# Number of concurrent NIM requests when OCR-ing a multi-page PDF. Default: 4
# NVIDIA_NIM_CONCURRENCY=4

###########################################
########## BROWSER / WEB SCRAPING #########
###########################################
# Maximum time (ms) to wait when acquiring a Playwright browser from the pool. Default: 30000
# BROWSER_POOL_ACQUIRE_TIMEOUT_MS=30000

# Set to "true" to allow the dev integrity bypass header (X-Sin-Dev-Bypass).
# Must never be enabled in production.
# SIN_ALLOW_INSECURE_DEV_BYPASS=false

###########################################
########## BUNDESTAG DIP API ##############
###########################################
# API key for the German Bundestag DIP document search API.
# A public demo key is used as fallback but will hit rate limits quickly.
# BUNDESTAG_DIP_API_KEY=
