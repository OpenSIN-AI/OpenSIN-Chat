# SkillOpt / SkillOpt-Sleep environment (copy to .env or load with set -a; source .env.skillopt)
# For target (the agent being optimized) and optimizer (usually stronger model).

# Example for Claude as backend (common for coding agents)
# ANTHROPIC_API_KEY=sk-ant-...

# Or OpenAI / Azure
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_ENDPOINT=...
# AZURE_OPENAI_API_KEY=...

# For local OpenAI-compatible (Ollama, llama.cpp, vLLM, LM Studio etc.)
# OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPAT_API_KEY=local
# Then in skillopt-sleep / config use --backend openai_compatible or appropriate.

# SkillOpt source checkout (for scripts when not relying on installed CLI)
# SKILLOPT_ROOT=/Users/jeremy/dev/SkillOpt

# Recommended: load before running sleep
# set -a; source .env.skillopt; set +a
