# ============================================================
# OpenSIN Chat — docker-opensin Stack
# Kopiere diese Datei nach .env und fülle die Werte aus:
#   cp .env.example .env
# .env wird NICHT committet (siehe .gitignore).
# ============================================================

SERVER_PORT=3001
STORAGE_DIR="/app/server/storage"
UID='1000'
GID='1000'

# ---- Pflicht-Secrets (jeweils mit openssl erzeugen) ----
# openssl rand -hex 32
SIG_KEY=
# openssl rand -hex 16
SIG_SALT=
# openssl rand -hex 24   (nötig sobald AUTH_TOKEN/Multi-User aktiv)
JWT_SECRET=
# JWT_EXPIRY="30d"

# ---- LLM-Provider (Beispiel: NVIDIA NIM) ----
# Vollständige Provider-Liste: siehe ../docker/.env.example
LLM_PROVIDER='generic-openai'
GENERIC_OPEN_AI_BASE_PATH=
GENERIC_OPEN_AI_API_KEY=
GENERIC_OPEN_AI_MODEL_PREF=
GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT=4096

# ---- Embeddings (Standard: nativ, kein Key nötig) ----
# EMBEDDING_ENGINE='native'

# ---- Vector-DB (Standard: LanceDB, kein Key nötig) ----
# VECTOR_DB='lancedb'

# ---- Optionales Demo-Gate (NUR Hürde, kein echter Schutz) ----
# Wird ins Frontend-Bundle gebacken -> niemals echtes Secret!
# VITE_DEMO_PASSWORD=
