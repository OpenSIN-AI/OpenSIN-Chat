# ============================================================
# OpenSIN Chat — docker-opensin Stack
#
# Kopieren:
#   cp .env.example .env
#
# Die echte .env-Datei darf niemals committet werden.
# ============================================================

SERVER_PORT=3001

UID=1000
GID=1000

COMPOSE_BIND_ADDRESS=127.0.0.1
COMPOSE_PORT=43939
COMPOSE_CONTAINER_NAME=opensin-chat

OPENSIN_IMAGE_REPOSITORY=opensin-chat
OPENSIN_IMAGE_TAG=local

STORAGE_DIR=/app/server/storage
DATABASE_URL=file:/app/server/storage/opensin.db

# Optionale Cross-Origin-Frontends, durch Komma getrennt. Same-Origin funktioniert
# ohne diese Angabe. In Produktion niemals "*" verwenden.
# CORS_ORIGIN=https://sinchat.example.org

# Request- und Upload-Sicherheitslimits.
COLLECTOR_BODY_LIMIT=50mb
MAX_COLLECTOR_FILE_SIZE_BYTES=524288000
BODY_LIMIT=50mb

# Chromium bleibt standardmäßig außerhalb des Images.
SKIP_CHROMIUM=1
CHROMIUM_SHA256=
CHROMIUM_DOWNLOAD_URL=https://webassets.anythingllm.com/chromium-1088-linux-arm64.zip

# ============================================================
# Pflicht-Secrets
# ============================================================

# openssl rand -hex 32
SIG_KEY=

# openssl rand -hex 16
SIG_SALT=

# openssl rand -hex 32
JWT_SECRET=

# Optional:
# JWT_EXPIRY=30d

# ============================================================
# Riskante optionale Funktionen
#
# Backend- und Frontend-Flag müssen beide aktiviert werden.
# Standard bleibt bewusst false.
# ============================================================

ENABLE_IMAGE_GENERATION=false
ENABLE_VIDEO_GENERATION=false
ENABLE_CVOICE_TTS=false

VITE_ENABLE_IMAGE_GENERATION=false
VITE_ENABLE_VIDEO_GENERATION=false
VITE_ENABLE_CVOICE_TTS=false

# ============================================================
# LLM-Provider
# ============================================================

LLM_PROVIDER=generic-openai
GENERIC_OPEN_AI_BASE_PATH=
GENERIC_OPEN_AI_API_KEY=
GENERIC_OPEN_AI_MODEL_PREF=
GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT=4096

# ============================================================
# Embeddings und Vector-DB
# ============================================================

# EMBEDDING_ENGINE=native
# VECTOR_DB=lancedb

# ============================================================
# Optionales Demo-Gate
#
# Kein echtes Secret: VITE-Werte landen im Browser-Bundle.
# ============================================================

# VITE_DEMO_PASSWORD=
