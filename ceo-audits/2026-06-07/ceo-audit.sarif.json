{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SIN-Code CEO Audit",
          "version": "v3",
          "informationUri": "https://github.com/OpenSIN-Code/SIN-Code-Bundle",
          "rules": [
            {"id": "SIN-4.1", "name": "CoverageBelowThreshold", "shortDescription": {"text": "Test coverage < 70%"}, "defaultConfiguration": {"level": "warning"}},
            {"id": "SIN-4.4", "name": "MissingEdgeCaseTests", "shortDescription": {"text": "No edge-case tests"}, "defaultConfiguration": {"level": "warning"}},
            {"id": "SIN-5.3", "name": "UnpinnedDependency", "shortDescription": {"text": "Unpinned critical dependency"}, "defaultConfiguration": {"level": "warning"}},
            {"id": "SIN-7.4", "name": "HotPathNotTested", "shortDescription": {"text": "Hot path not covered by tests"}, "defaultConfiguration": {"level": "warning"}},
            {"id": "SIN-8.3", "name": "MissingSBOM", "shortDescription": {"text": "No SBOM in repository"}, "defaultConfiguration": {"level": "note"}},
            {"id": "SIN-8.1", "name": "MissingLicenseHeader", "shortDescription": {"text": "SPDX license header missing"}, "defaultConfiguration": {"level": "note"}}
          ]
        }
      },
      "results": [
        {
          "ruleId": "SIN-4.1",
          "level": "warning",
          "message": {"text": "Test coverage ratio 1:36 (30 jest tests for 538 source files). New background-job-queue (queue.js, generateTitle.js) has 0 jest tests."},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "server/utils/backgroundJobs/queue.js"}}}]
        },
        {
          "ruleId": "SIN-4.4",
          "level": "warning",
          "message": {"text": "Queue: missing edge-case tests for concurrent add(), large payloads (>10KB), non-2xx LLM responses, partial Prisma failures."},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "server/utils/backgroundJobs/queue.js"}}}]
        },
        {
          "ruleId": "SIN-5.3",
          "level": "warning",
          "message": {"text": "Critical top-level deps unpinned: langchain (^0.3.0), openai (^6.0.0), express (^5.0.0). Float to latest minor on yarn install."},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "server/package.json"}}}]
        },
        {
          "ruleId": "SIN-7.4",
          "level": "warning",
          "message": {"text": "_processNextJob is the queue hot path — not yet covered by automated tests (manual smoke tests pass)."},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "server/utils/backgroundJobs/queue.js"}}}]
        },
        {
          "ruleId": "SIN-8.3",
          "level": "note",
          "message": {"text": "No SBOM in repository. Generate via: sin-code sbom --format spdx-json --output sbom.json"},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "."}}}]
        },
        {
          "ruleId": "SIN-8.1",
          "level": "note",
          "message": {"text": "3 server JS files missing SPDX-License-Identifier header: server/swagger/* (auto-generated), server/jobs/helpers/index.js"},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "server/jobs/helpers/index.js"}}}]
        }
      ]
    }
  ]
}
