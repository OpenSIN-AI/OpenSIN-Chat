# SPDX-License-Identifier: MIT
# Purpose: Reduce Docker build context and prevent large / secret files from being copied into the image.
# Docs: .dockerignore.doc.md

# Git metadata
.git
.gitignore

# Node dependencies (reinstalled inside the image)
node_modules
frontend/node_modules
server/node_modules
collector/node_modules

# Build outputs (rebuilt inside the image)
frontend/dist
frontend/coverage
server/coverage
*.log

# Runtime data (mounted as volumes, not baked into the image)
server/storage
collector/hotdir
collector/outputs

# Docker / env files (mounted at runtime or contain secrets)
docker/.env
docker-opensin/.env
.env
.env.example

# IDE / OS noise
.DS_Store
.vscode
.idea
*.swp
*.swo

# OpenSIN tooling / CI / internal directories (not needed in the image)
.sin
.sin-code
.pcpm
.claude
.github
n8n
ceo-audits
history
images
extras
locales
docker-opensin

# Test artifacts and large downloads
frontend/.vitest
coverage
.nyc_output
chrome-linux
chrome-linux.zip

# Documentation only
*.md
!README.md
docs
