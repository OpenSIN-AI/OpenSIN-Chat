    "i18next-resources-to-backend": "^1.2.1",
    "js-levenshtein": "^1.1.6",
    "jspdf": "^4.2.1",
    "katex": "^0.17.0",
    "lodash.debounce": "^4.0.8",
    "markdown-it": "^14.3.0",
