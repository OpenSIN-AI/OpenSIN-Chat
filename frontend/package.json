    "tailwindcss": "^4.0.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@^7.0.2",
    "typescript-eslint": "^8.62.1",
    "util": "^0.12.5",
    "vite": "8.1.4",
    "vite-plugin-image-optimizer": "^2.0.0",
