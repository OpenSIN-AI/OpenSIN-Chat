{
  "name": "opensin-chat-frontend",
  "version": "1.14.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "vite --open",
    "predev": "npm run sync:docs",
    "dev": "cross-env NODE_ENV=development vite --debug --host=0.0.0.0",
    "prebuild": "npm run sync:docs",
    "build": "vite build && node scripts/postbuild.js",
    "sync:docs": "node scripts/sync-docs.js",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "audit:prepare": "npm install --package-lock-only --legacy-peer-deps --no-audit --no-fund",
    "audit": "npm run audit:prepare && npm audit --audit-level=moderate",
    "audit:high": "npm run audit:prepare && npm audit --audit-level=high",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:utils": "vitest run src/utils",
    "test:models": "vitest run src/models",
    "test:hooks-1": "vitest run src/hooks --shard=1/2",
    "test:hooks-2": "vitest run src/hooks --shard=2/2",
    "test:components-1": "vitest run src/components src/pages --shard=1/2",
    "test:components-2": "vitest run src/components src/pages --shard=2/2",
    "test:hooks": "vitest run src/hooks",
    "test:components": "vitest run src/components src/pages",
    "verify:translations": "node src/locales/verifyTranslations.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "find:unused-translations": "node src/locales/findUnusedTranslations.mjs",
    "clean:unused-translations": "node src/locales/findUnusedTranslations.mjs --delete",
    "normalize:translations": "node src/locales/normalizeEn.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "clean": "rm -rf dist node_modules/.cache",
    "type-check": "tsc --noEmit -p tsconfig.check.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@lobehub/icons": "^5.10.1",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
