    "pluralize": "^8.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-device-detect": "^2.2.2",
    "react-dom": "^19.1.0",
    "react-dropzone": "^15.0.0",
    "react-error-boundary": "^6.1.2",
    "react-highlight-words": "^0.21.0",
    "react-i18next": "^17.0.9",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
