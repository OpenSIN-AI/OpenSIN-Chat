{
  "name": "opensin-chat-frontend",
  "version": "1.14.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "vite --open",
    "predev": "npm run sync:docs",
    "dev": "cross-env NODE_ENV=development vite --debug --host=0.0.0.0",
    "prebuild": "npm run sync:docs",
    "build": "vite build && node scripts/postbuild.js",
    "sync:docs": "node scripts/sync-docs.js",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "audit:prepare": "npm install --package-lock-only --legacy-peer-deps --no-audit --no-fund",
    "audit": "npm run audit:prepare && npm audit --audit-level=moderate",
    "audit:high": "npm run audit:prepare && npm audit --audit-level=high",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:utils": "vitest run src/utils",
    "test:models": "vitest run src/models",
    "test:hooks-1": "vitest run src/hooks --shard=1/2",
    "test:hooks-2": "vitest run src/hooks --shard=2/2",
    "test:components-1": "vitest run src/components src/pages --shard=1/2",
    "test:components-2": "vitest run src/components src/pages --shard=2/2",
    "test:hooks": "vitest run src/hooks",
    "test:components": "vitest run src/components src/pages",
    "verify:translations": "node src/locales/verifyTranslations.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "find:unused-translations": "node src/locales/findUnusedTranslations.mjs",
    "clean:unused-translations": "node src/locales/findUnusedTranslations.mjs --delete",
    "normalize:translations": "node src/locales/normalizeEn.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@lobehub/icons": "^4.0.3",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@phosphor-icons/react": "^2.1.10",
    "@tremor/react": "^3.18.7",
    "cronstrue": "^2.50.0",
    "dayjs": "^1.11.21",
    "docx": "^9.7.1",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "file-saver": "^2.0.5",
    "he": "^1.2.0",
    "highlight.js": "^11.11.1",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "js-levenshtein": "^1.1.6",
    "jspdf": "^4.2.1",
    "katex": "^0.16.11",
    "lodash.debounce": "^4.0.8",
    "markdown-it": "^14.2.0",
    "onnxruntime-web": "^1.18.0",
    "pluralize": "^8.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-confetti-explosion": "^2.1.2",
    "react-device-detect": "^2.2.2",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.2.3",
    "react-error-boundary": "^6.1.2",
    "react-highlight-words": "^0.21.0",
    "react-i18next": "^14.1.1",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.30.4",
    "react-speech-recognition": "4.0.1",
    "react-tag-input-component": "^2.0.2",
    "react-toastify": "^9.1.3",
    "react-tooltip": "6.0.8",
    "react-virtuoso": "^4.18.7",
    "recharts": "^2.12.5",
    "recharts-to-png": "^2.3.1",
    "regenerator-runtime": "^0.14.1",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "text-case": "^1.0.9",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "autoprefixer": "^10.5.0",
    "buffer": "^6.0.3",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-ft-flow": "^3.0.0",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "flow-bin": "^0.217.0",
    "flow-remove-types": "^2.319.0",
    "globals": "^16.5.0",
    "hermes-eslint": "0.36.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "8.5.16",
    "prettier": "^3.0.3",
    "rollup-plugin-visualizer": "^5.9.0",
    "tailwindcss": "^3.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "resolutions": {
    "dompurify": ">=3.4.11",
    "protobufjs": "^7.5.6",
    "@remix-run/router": "^1.23.2",
    "lodash": "^4.18.0",
    "flatted": "^3.4.2",
    "minimatch": "^3.1.4",
    "picomatch": "^2.3.2",
    "glob": "^10.5.0",
    "cross-spawn": "^7.0.5",
    "@babel/runtime": "^7.26.10",
    "@babel/helpers": "^7.26.10",
    "brace-expansion": "^1.1.13",
    "nanoid": "^3.3.8",
    "micromatch": "^4.0.8",
    "ajv": "^6.14.0",
    "react-router": "^6.30.4",
    "postcss": "^8.5.10",
    "yaml": "^2.8.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
