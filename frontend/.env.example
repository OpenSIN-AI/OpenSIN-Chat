# Development server security: defaults to loopback only.
# Set VITE_DEV_HOST=0.0.0.0 only when LAN/container/tunnel access is required.
# VITE_DEV_HOST=127.0.0.1

# VITE_API_BASE defaults to "/api" (relative → same-origin → works with CSP
# "connect-src 'self'" and the dev-mode vite proxy on http://localhost:3000).
# Only override if the frontend is served from a different origin than the API:
#
# VITE_API_BASE='http://localhost:3001/api'              # local dev WITHOUT the vite proxy
# VITE_API_BASE="https://api.example.com/api"             # cross-origin production
# VITE_API_BASE="https://$CODESPACE_NAME-3001.$GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN/api" # GitHub Codespaces
